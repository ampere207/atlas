APP_NAME=Atlas - Distributed Intelligent RAG Engine
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
QUERY_CLASSIFIER_BACKEND=fast
QUERY_CLASSIFIER_USE_SEMANTIC=true
QUERY_CLASSIFIER_MODEL=sentence-transformers/all-MiniLM-L6-v2

POSTGRES_DSN=postgresql+asyncpg://atlas:atlas@localhost:5432/atlas
REDIS_URL=redis://localhost:6379/0

DEFAULT_TOP_K=5
CACHE_TTL_SECONDS=900
USE_PLACEHOLDER_RETRIEVAL=true
