APP_NAME=Atlas - Distributed Intelligent RAG Engine
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
QUERY_CLASSIFIER_BACKEND=fast
QUERY_CLASSIFIER_USE_SEMANTIC=true
QUERY_CLASSIFIER_MODEL=sentence-transformers/all-MiniLM-L6-v2

EMBEDDING_MODEL_NAME=BAAI/bge-small-en
RERANKER_MODEL_NAME=BAAI/bge-reranker-base

POSTGRES_DSN=postgresql+asyncpg://atlas:atlas@localhost:5432/atlas
REDIS_URL=redis://localhost:6379/0
NEO4J_URI=neo4j://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=documents
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX_NAME=documents_index

DEFAULT_TOP_K=5
CHUNK_SIZE_TOKENS=500
CHUNK_OVERLAP_TOKENS=100
CONTEXT_MAX_TOKENS=1800
ENABLE_METRICS=true
RETRIEVAL_LATENCY_THRESHOLD_MS=1000
CACHE_TTL_SECONDS=900
CACHE_SIMILARITY_THRESHOLD=0.98
CACHE_MAX_ENTRIES=500
USE_PLACEHOLDER_RETRIEVAL=false
